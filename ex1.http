{
  "predicates": [
    {
      "equals": {
        "method": "GET",
        "path": "/api/marcas"
      }
    }
  ],
  "responses": [
    {
      "is": {
        "statusCode": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "marcas": ["Toyota", "Audi", "Ford"]
        }
      }
    }
  ]
}